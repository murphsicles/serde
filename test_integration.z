extern fn putchar(c: i64) -> i64;
extern fn println_i64(v: i64);

// Print a character n times
fn repeat_char(c: i64, n: i64) {
    let mut i: i64 = 0;
    while i < n {
        putchar(c);
        i = i + 1;
    }
}

fn main() -> i64 {
    // Header
    repeat_char(61, 40); // ===
    putchar(10); // newline
    
    // Simple JSON: {"serde":1,"zorb":"test"}
    putchar(123); // {
    
    putchar(34); // "
    putchar(115); // s
    putchar(101); // e
    putchar(114); // r
    putchar(100); // d
    putchar(101); // e
    putchar(34); // "
    putchar(58); // :
    println_i64(1);
    
    putchar(44); // ,
    
    putchar(34); // "
    putchar(122); // z
    putchar(111); // o
    putchar(114); // r
    putchar(98);  // b
    putchar(34); // "
    putchar(58); // :
    
    putchar(34); // "
    putchar(116); // t
    putchar(101); // e
    putchar(115); // s
    putchar(116); // t
    putchar(34); // "
    
    putchar(125); // }
    putchar(10); // newline
    
    // Footer
    repeat_char(61, 40); // ===
    putchar(10);
    
    return 0;
}
