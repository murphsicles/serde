// test_serde.z
// Comprehensive test for the Serde serialization framework in Zeta
//
// Tests JSON serialization and deserialization of complex data types.

// ═══════════════════════════════════════════════════════════════════════════
// External functions for output
// ═══════════════════════════════════════════════════════════════════════════

extern fn putchar(c: i64) -> i64;
extern fn printf(fmt: &str) -> i64;

// ═══════════════════════════════════════════════════════════════════════════
// Serde Data Model
// ═══════════════════════════════════════════════════════════════════════════

// Represents a serialized JSON-like value tree
enum JsonValue {
    Null,
    Bool(bool),
    Number(i64),
    String(String),
    Array(Vec<JsonValue>),
    Object(Vec<(String, JsonValue)>),
}

// ─── Helper Functions ─────────────────────────────────────────────────────

fn json_value_is_null(value: &JsonValue) -> bool {
    match value {
        JsonValue::Null => true,
        _ => false,
    }
}

fn json_value_is_bool(value: &JsonValue) -> bool {
    match value {
        JsonValue::Bool(_) => true,
        _ => false,
    }
}

fn json_value_is_number(value: &JsonValue) -> bool {
    match value {
        JsonValue::Number(_) => true,
        _ => false,
    }
}

fn json_value_is_string(value: &JsonValue) -> bool {
    match value {
        JsonValue::String(_) => true,
        _ => false,
    }
}

fn json_value_is_array(value: &JsonValue) -> bool {
    match value {
        JsonValue::Array(_) => true,
        _ => false,
    }
}

fn json_value_is_object(value: &JsonValue) -> bool {
    match value {
        JsonValue::Object(_) => true,
        _ => false,
    }
}

fn clone_json_value(v: &JsonValue) -> JsonValue {
    match v {
        JsonValue::Null => JsonValue::Null,
        JsonValue::Bool(b) => JsonValue::Bool(*b),
        JsonValue::Number(n) => JsonValue::Number(*n),
        JsonValue::String(s) => JsonValue::String(s.clone()),
        JsonValue::Array(items) => {
            let mut new_items: Vec<JsonValue> = vec![];
            let mut i = 0;
            while i < items.len() {
                new_items.push(clone_json_value(&items[i]));
                i = i + 1;
            }
            JsonValue::Array(new_items)
        }
        JsonValue::Object(entries) => {
            let mut new_entries: Vec<(String, JsonValue)> = vec![];
            let mut i = 0;
            while i < entries.len() {
                let (k, v) = &entries[i];
                new_entries.push((k.clone(), clone_json_value(v)));
                i = i + 1;
            }
            JsonValue::Object(new_entries)
        }
    }
}

// ─── Object Builder ───────────────────────────────────────────────────────

struct ObjectBuilder {
    entries: Vec<(String, JsonValue)>,
}

fn new_object_builder() -> ObjectBuilder {
    ObjectBuilder { entries: vec![] }
}

fn object_builder_insert(builder: &mut ObjectBuilder, key: &str, value: JsonValue) {
    builder.entries.push((String::from(key), value));
}

fn object_builder_build(builder: ObjectBuilder) -> JsonValue {
    JsonValue::Object(builder.entries)
}

// ─── Array Builder ────────────────────────────────────────────────────────

struct ArrayBuilder {
    items: Vec<JsonValue>,
}

fn new_array_builder() -> ArrayBuilder {
    ArrayBuilder { items: vec![] }
}

fn array_builder_push(builder: &mut ArrayBuilder, value: JsonValue) {
    builder.items.push(value);
}

fn array_builder_build(builder: ArrayBuilder) -> JsonValue {
    JsonValue::Array(builder.items)
}

// ─── Object Access ────────────────────────────────────────────────────────

fn object_get(obj: &JsonValue, key: &str) -> JsonValue {
    match obj {
        JsonValue::Object(entries) => {
            let mut i = 0;
            while i < entries.len() {
                let (k, v) = &entries[i];
                if k == key {
                    return v.clone();
                }
                i = i + 1;
            }
            JsonValue::Null
        }
        _ => JsonValue::Null,
    }
}

fn object_len(obj: &JsonValue) -> i64 {
    match obj {
        JsonValue::Object(entries) => entries.len() as i64,
        _ => 0,
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// JSON Serializer
// ═══════════════════════════════════════════════════════════════════════════

fn escape_json_string(s: &str) -> String {
    let mut result = String::new();
    let mut i = 0;
    while i < s.len() {
        let ch = s[i];
        if ch == '"' as u8 {
            result.push_str("\\\"");
        } else if ch == '\\' as u8 {
            result.push_str("\\\\");
        } else if ch == '\n' as u8 {
            result.push_str("\\n");
        } else if ch == '\r' as u8 {
            result.push_str("\\r");
        } else if ch == '\t' as u8 {
            result.push_str("\\t");
        } else {
            result.push(ch);
        }
        i = i + 1;
    }
    result
}

fn json_to_string(value: &JsonValue) -> String {
    match value {
        JsonValue::Null => String::from("null"),
        JsonValue::Bool(v) => {
            if *v { String::from("true") } else { String::from("false") }
        }
        JsonValue::Number(v) => to_string_i64(*v),
        JsonValue::String(v) => {
            let mut result = String::from("\"");
            result.push_str(escape_json_string(v.as_str()).as_str());
            result.push_str("\"");
            result
        }
        JsonValue::Array(items) => {
            let mut result = String::from("[");
            let mut i = 0;
            while i < items.len() {
                if i > 0 {
                    result.push_str(",");
                }
                result.push_str(json_to_string(&items[i]).as_str());
                i = i + 1;
            }
            result.push_str("]");
            result
        }
        JsonValue::Object(entries) => {
            let mut result = String::from("{");
            let mut i = 0;
            while i < entries.len() {
                if i > 0 {
                    result.push_str(",");
                }
                let (key, value) = &entries[i];
                result.push_str("\"");
                result.push_str(escape_json_string(key.as_str()).as_str());
                result.push_str("\":");
                result.push_str(json_to_string(value).as_str());
                i = i + 1;
            }
            result.push_str("}");
            result
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// JSON Parser
// ═══════════════════════════════════════════════════════════════════════════

struct JsonParser {
    input: String,
    pos: i64,
}

fn new_json_parser(input: &str) -> JsonParser {
    JsonParser {
        input: String::from(input),
        pos: 0,
    }
}

fn skip_whitespace(parser: &mut JsonParser) {
    while parser.pos < parser.input.len() {
        let ch = parser.input[parser.pos as usize];
        if ch == ' ' as u8 || ch == '\n' as u8 || ch == '\r' as u8 || ch == '\t' as u8 {
            parser.pos = parser.pos + 1;
        } else {
            break;
        }
    }
}

fn hex_digit_value(ch: u8) -> i64 {
    if ch >= '0' as u8 && ch <= '9' as u8 {
        (ch - '0' as u8) as i64
    } else if ch >= 'a' as u8 && ch <= 'f' as u8 {
        (ch - 'a' as u8 + 10) as i64
    } else if ch >= 'A' as u8 && ch <= 'F' as u8 {
        (ch - 'A' as u8 + 10) as i64
    } else {
        0
    }
}

fn parse_hex4(parser: &mut JsonParser) -> i64 {
    let mut value: i64 = 0;
    let mut i = 0;
    while i < 4 && parser.pos < parser.input.len() {
        let ch = parser.input[parser.pos as usize];
        value = value * 16 + hex_digit_value(ch);
        parser.pos = parser.pos + 1;
        i = i + 1;
    }
    value
}

fn parse_string_value(parser: &mut JsonParser) -> JsonValue {
    parser.pos = parser.pos + 1;  // skip opening quote
    let mut result = String::new();

    while parser.pos < parser.input.len() {
        let ch = parser.input[parser.pos as usize];
        if ch == '"' as u8 {
            parser.pos = parser.pos + 1;
            return JsonValue::String(result);
        } else if ch == '\\' as u8 {
            parser.pos = parser.pos + 1;
            if parser.pos < parser.input.len() {
                let next = parser.input[parser.pos as usize];
                if next == '"' as u8 { result.push('"'); }
                else if next == '\\' as u8 { result.push('\\'); }
                else if next == '/' as u8 { result.push('/'); }
                else if next == 'n' as u8 { result.push('\n'); }
                else if next == 'r' as u8 { result.push('\r'); }
                else if next == 't' as u8 { result.push('\t'); }
                else if next == 'u' as u8 {
                    parser.pos = parser.pos + 1;
                    let code = parse_hex4(parser);
                    result.push(code as u8);
                }
                parser.pos = parser.pos + 1;
            }
        } else {
            result.push(ch);
            parser.pos = parser.pos + 1;
        }
    }
    JsonValue::String(result)
}

fn parse_int_str(s: &str) -> i64 {
    let mut i = 0;
    let mut neg = false;
    let mut val: i64 = 0;

    if i < s.len() && s[i] == '-' as u8 {
        neg = true;
        i = i + 1;
    }
    while i < s.len() {
        val = val * 10 + (s[i] - '0' as u8) as i64;
        i = i + 1;
    }
    if neg { -val } else { val }
}

fn parse_number_value(parser: &mut JsonParser) -> JsonValue {
    let start = parser.pos;
    if parser.pos < parser.input.len() && parser.input[parser.pos as usize] == '-' as u8 {
        parser.pos = parser.pos + 1;
    }
    while parser.pos < parser.input.len() {
        let ch = parser.input[parser.pos as usize];
        if ch >= '0' as u8 && ch <= '9' as u8 {
            parser.pos = parser.pos + 1;
        } else {
            break;
        }
    }
    let num_str = parser.input[start as usize..parser.pos as usize].to_string();
    JsonValue::Number(parse_int_str(num_str.as_str()))
}

fn parse_bool_value(parser: &mut JsonParser) -> JsonValue {
    if parser.input[parser.pos as usize] == 't' as u8 {
        parser.pos = parser.pos + 4;
        JsonValue::Bool(true)
    } else {
        parser.pos = parser.pos + 5;
        JsonValue::Bool(false)
    }
}

fn parse_null_value(parser: &mut JsonParser) -> JsonValue {
    parser.pos = parser.pos + 4;
    JsonValue::Null
}

fn parse_value(parser: &mut JsonParser) -> JsonValue {
    skip_whitespace(parser);
    if parser.pos >= parser.input.len() {
        return JsonValue::Null;
    }
    let ch = parser.input[parser.pos as usize];
    if ch == '"' as u8 {
        parse_string_value(parser)
    } else if ch == '{' as u8 {
        parse_object(parser)
    } else if ch == '[' as u8 {
        parse_array(parser)
    } else if ch == 't' as u8 || ch == 'f' as u8 {
        parse_bool_value(parser)
    } else if ch == 'n' as u8 {
        parse_null_value(parser)
    } else if ch == '-' as u8 || (ch >= '0' as u8 && ch <= '9' as u8) {
        parse_number_value(parser)
    } else {
        JsonValue::Null
    }
}

fn parse_object(parser: &mut JsonParser) -> JsonValue {
    parser.pos = parser.pos + 1;  // skip '{'
    let mut entries: Vec<(String, JsonValue)> = vec![];

    skip_whitespace(parser);
    if parser.pos < parser.input.len() && parser.input[parser.pos as usize] == '}' as u8 {
        parser.pos = parser.pos + 1;
        return JsonValue::Object(entries);
    }

    let mut first = true;
    while parser.pos < parser.input.len() {
        skip_whitespace(parser);
        if parser.input[parser.pos as usize] == '}' as u8 {
            parser.pos = parser.pos + 1;
            return JsonValue::Object(entries);
        }
        if !first {
            if parser.input[parser.pos as usize] == ',' as u8 {
                parser.pos = parser.pos + 1;
                skip_whitespace(parser);
            }
        }
        first = false;

        let key_val = parse_string_value(parser);
        let key = match &key_val {
            JsonValue::String(s) => s.clone(),
            _ => String::new(),
        };

        skip_whitespace(parser);
        if parser.pos < parser.input.len() && parser.input[parser.pos as usize] == ':' as u8 {
            parser.pos = parser.pos + 1;
        }

        let value = parse_value(parser);
        entries.push((key, value));
    }
    JsonValue::Object(entries)
}

fn parse_array(parser: &mut JsonParser) -> JsonValue {
    parser.pos = parser.pos + 1;  // skip '['
    let mut items: Vec<JsonValue> = vec![];

    skip_whitespace(parser);
    if parser.pos < parser.input.len() && parser.input[parser.pos as usize] == ']' as u8 {
        parser.pos = parser.pos + 1;
        return JsonValue::Array(items);
    }

    let mut first = true;
    while parser.pos < parser.input.len() {
        skip_whitespace(parser);
        if parser.input[parser.pos as usize] == ']' as u8 {
            parser.pos = parser.pos + 1;
            return JsonValue::Array(items);
        }
        if !first {
            if parser.input[parser.pos as usize] == ',' as u8 {
                parser.pos = parser.pos + 1;
                skip_whitespace(parser);
            }
        }
        first = false;
        items.push(parse_value(parser));
    }
    JsonValue::Array(items)
}

fn parse_json(input: &str) -> JsonValue {
    let mut parser = new_json_parser(input);
    skip_whitespace(&mut parser);
    parse_value(&mut parser)
}

// ═══════════════════════════════════════════════════════════════════════════
// Print Helpers
// ═══════════════════════════════════════════════════════════════════════════

fn print_string(s: &str) {
    let bytes = s.as_bytes();
    let mut i = 0;
    while i < s.len() {
        putchar(s[i] as i64);
        i = i + 1;
    }
}

fn print_json_value(value: &JsonValue, indent: i64) {
    match value {
        JsonValue::Null => print_string("null"),
        JsonValue::Bool(v) => {
            if *v { print_string("true") } else { print_string("false") }
        }
        JsonValue::Number(v) => {
            let s = to_string_i64(*v);
            print_string(s.as_str());
        }
        JsonValue::String(v) => {
            print_string("\"");
            print_string(escape_json_string(v.as_str()).as_str());
            print_string("\"");
        }
        JsonValue::Array(items) => {
            print_string("[\n");
            let mut i = 0;
            while i < items.len() {
                let mut j = 0;
                while j < indent + 2 {
                    print_string("  ");
                    j = j + 1;
                }
                if i > 0 { print_string(",\n"); }
                print_json_value(&items[i], indent + 1);
                i = i + 1;
            }
            print_string("\n");
            let mut j = 0;
            while j < indent {
                print_string("  ");
                j = j + 1;
            }
            print_string("]");
        }
        JsonValue::Object(entries) => {
            print_string("{\n");
            let mut i = 0;
            while i < entries.len() {
                let mut j = 0;
                while j < indent + 2 {
                    print_string("  ");
                    j = j + 1;
                }
                if i > 0 { print_string(",\n"); }
                let (key, val) = &entries[i];
                print_string("\"");
                print_string(escape_json_string(key.as_str()).as_str());
                print_string("\": ");
                print_json_value(val, indent + 1);
                i = i + 1;
            }
            print_string("\n");
            let mut j = 0;
            while j < indent {
                print_string("  ");
                j = j + 1;
            }
            print_string("}");
        }
    }
}

fn print_line(s: &str) {
    print_string(s);
    putchar(10);  // newline
}

fn print_int(n: i64) {
    let s = to_string_i64(n);
    print_string(s.as_str());
}

// ═══════════════════════════════════════════════════════════════════════════
// Test Functions
// ═══════════════════════════════════════════════════════════════════════════

// Test 1: Serialize a simple object
fn test_serialize_object() -> i64 {
    let mut obj = new_object_builder();
    object_builder_insert(&mut obj, "name", JsonValue::String(String::from("Alice")));
    object_builder_insert(&mut obj, "age", JsonValue::Number(30));
    object_builder_insert(&mut obj, "active", JsonValue::Bool(true));
    let value = object_builder_build(obj);

    let json_str = json_to_string(&value);
    print_line("Test 1 - Serialize object:");
    print_line(json_str.as_str());
    1
}

// Test 2: Serialize a nested object
fn test_serialize_nested() -> i64 {
    let mut addr = new_object_builder();
    object_builder_insert(&mut addr, "city", JsonValue::String(String::from("New York")));
    object_builder_insert(&mut addr, "zip", JsonValue::Number(10001));
    let addr_val = object_builder_build(addr);

    let mut person = new_object_builder();
    object_builder_insert(&mut person, "name", JsonValue::String(String::from("Bob")));
    object_builder_insert(&mut person, "address", addr_val);
    let value = object_builder_build(person);

    let json_str = json_to_string(&value);
    print_line("Test 2 - Serialize nested object:");
    print_line(json_str.as_str());
    2
}

// Test 3: Serialize an array
fn test_serialize_array() -> i64 {
    let mut arr = new_array_builder();
    array_builder_push(&mut arr, JsonValue::Number(1));
    array_builder_push(&mut arr, JsonValue::Number(2));
    array_builder_push(&mut arr, JsonValue::Number(3));
    let value = array_builder_build(arr);

    let json_str = json_to_string(&value);
    print_line("Test 3 - Serialize array:");
    print_line(json_str.as_str());
    3
}

// Test 4: Mixed array with objects
fn test_serialize_mixed_array() -> i64 {
    let mut arr = new_array_builder();
    array_builder_push(&mut arr, JsonValue::Number(42));
    array_builder_push(&mut arr, JsonValue::Bool(true));
    array_builder_push(&mut arr, JsonValue::String(String::from("hello")));
    array_builder_push(&mut arr, JsonValue::Null);
    let value = array_builder_build(arr);

    let json_str = json_to_string(&value);
    print_line("Test 4 - Mixed array:");
    print_line(json_str.as_str());
    4
}

// Test 5: Parse and re-serialize (roundtrip)
fn test_parse_roundtrip() -> i64 {
    let input = r#"{"name":"Charlie","age":25,"scores":[95,87,92],"active":true}"#;
    let parsed = parse_json(input);
    let output = json_to_string(&parsed);

    print_line("Test 5 - Parse & re-serialize:");
    print_line("Input:  ");
    print_line(input);
    print_line("Output: ");
    print_line(output.as_str());
    5
}

// Test 6: Parse simple object and access fields
fn test_parse_and_access() -> i64 {
    let input = r#"{"x":10,"y":20,"label":"point-a"}"#;
    let parsed = parse_json(input);

    let x = match object_get(&parsed, "x") {
        JsonValue::Number(n) => n,
        _ => 0,
    };
    let y = match object_get(&parsed, "y") {
        JsonValue::Number(n) => n,
        _ => 0,
    };
    let label = match object_get(&parsed, "label") {
        JsonValue::String(s) => s,
        _ => String::new(),
    };

    print_line("Test 6 - Parse & access:");
    print_string("  x = ");
    print_int(x);
    putchar(10);
    print_string("  y = ");
    print_int(y);
    putchar(10);
    print_string("  label = ");
    print_string(label.as_str());
    putchar(10);
    6
}

// Test 7: Parse array
fn test_parse_array() -> i64 {
    let input = r#"[10,20,30,40,50]"#;
    let parsed = parse_json(input);

    let len = match &parsed {
        JsonValue::Array(items) => items.len() as i64,
        _ => 0,
    };

    print_line("Test 7 - Parse array:");
    print_string("  length = ");
    print_int(len);
    putchar(10);
    7
}

// Test 8: Parse nested structure
fn test_parse_nested() -> i64 {
    let input = r#"{"person":{"name":"Diana","age":35},"tags":["admin","user"]}"#;
    let parsed = parse_json(input);

    let name = match object_get(&parsed, "person") {
        JsonValue::Object(_) => {
            match object_get(&parsed, "person") {
                JsonValue::Object(entries) => {
                    let mut i = 0;
                    let mut result = String::new();
                    while i < entries.len() {
                        let (k, v) = &entries[i];
                        if k == "name" {
                            match v {
                                JsonValue::String(s) => { result = s.clone(); }
                                _ => {}
                            }
                        }
                        i = i + 1;
                    }
                    result
                }
                _ => String::new(),
            }
        }
        _ => String::new(),
    };

    print_line("Test 8 - Parse nested:");
    print_string("  person.name = ");
    print_string(name.as_str());
    putchar(10);
    8
}

// Test 9: Pretty print JSON
fn test_pretty_print() -> i64 {
    let mut addr = new_object_builder();
    object_builder_insert(&mut addr, "street", JsonValue::String(String::from("123 Main St")));
    object_builder_insert(&mut addr, "city", JsonValue::String(String::from("Springfield")));
    let addr_val = object_builder_build(addr);

    let mut person = new_object_builder();
    object_builder_insert(&mut person, "name", JsonValue::String(String::from("Eve")));
    object_builder_insert(&mut person, "age", JsonValue::Number(28));
    object_builder_insert(&mut person, "address", addr_val);
    object_builder_insert(&mut person, "tags", JsonValue::Array(vec![
        JsonValue::String(String::from("dev")),
        JsonValue::String(String::from("ops")),
    ]));
    let value = object_builder_build(person);

    print_line("Test 9 - Pretty print:");
    print_json_value(&value, 0);
    putchar(10);
    9
}

// Test 10: Full roundtrip: build -> serialize -> parse -> print
fn test_full_roundtrip() -> i64 {
    // Build original
    let mut orig = new_object_builder();
    object_builder_insert(&mut orig, "type", JsonValue::String(String::from("test")));
    object_builder_insert(&mut orig, "value", JsonValue::Number(99));
    object_builder_insert(&mut orig, "flag", JsonValue::Bool(false));
    let original = object_builder_build(orig);

    // Serialize
    let json_str = json_to_string(&original);
    print_line("Test 10 - Full roundtrip:");
    print_string("  serialized: ");
    print_line(json_str.as_str());

    // Parse back
    let parsed = parse_json(json_str.as_str());
    let re_json = json_to_string(&parsed);
    print_string("  re-serialized: ");
    print_line(re_json.as_str());
    10
}

// ─── Main ─────────────────────────────────────────────────────────────────

fn main() -> i64 {
    print_line("=== Zeta Serde Test Suite ===");
    print_line("");

    let t1 = test_serialize_object();
    print_line("");

    let t2 = test_serialize_nested();
    print_line("");

    let t3 = test_serialize_array();
    print_line("");

    let t4 = test_serialize_mixed_array();
    print_line("");

    let t5 = test_parse_roundtrip();
    print_line("");

    let t6 = test_parse_and_access();
    print_line("");

    let t7 = test_parse_array();
    print_line("");

    let t8 = test_parse_nested();
    print_line("");

    let t9 = test_pretty_print();
    print_line("");

    let t10 = test_full_roundtrip();
    print_line("");

    print_line("=== All tests complete ===");
    0
}
